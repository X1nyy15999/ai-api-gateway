# ============================================
# AI API Gateway 环境变量配置
# ============================================

# --------------------------------------------
# ChatGPT 配置 (二选一)
# --------------------------------------------

# 方式1: Access Token (推荐，更稳定)
# 获取方法: 访问 https://chat.openai.com/api/auth/session
CHATGPT_ACCESS_TOKEN=

# 方式2: 账号密码 (可能触发人机验证)
# CHATGPT_EMAIL=
# CHATGPT_PASSWORD=

# ChatGPT 模型选择 (可选)
# 可选: gpt-4o, gpt-4o-mini, gpt-4, gpt-4-turbo, gpt-3.5-turbo
CHATGPT_MODEL=gpt-4o

# --------------------------------------------
# Claude 配置
# --------------------------------------------

# Session Key (必填)
# 获取方法: 访问 https://claude.ai → F12 → Application → Cookies → sessionKey
CLAUDE_SESSION_KEY=

# API 访问密钥 (自定义，用于保护接口)
CLAUDE_API_KEY=claude-api-key-123

# 自动删除对话 (true/false)
CLAUDE_CHAT_DELETE=true

# 最大历史长度
CLAUDE_MAX_HISTORY=10000

# --------------------------------------------
# 端口配置
# --------------------------------------------

CHATGPT_PORT=3040
CLAUDE_PORT=8080
